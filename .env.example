# ─────────────────────────────────────────
# MEMESCREENER 4.0 — CONFIG
# ─────────────────────────────────────────

# QuickNode Solana RPC (quicknode.com → free → Solana Mainnet)
QUICKNODE_RPC_URL=https://your-endpoint.solana-mainnet.quiknode.pro/YOUR_KEY/

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHI...
TELEGRAM_CHAT_ID=123456789

# NOTE: Jupiter API key is NOT set here — it's a runtime setting.
# Set it after first launch via Telegram: /setjupiter <your_key>
# Get a free key at https://portal.jup.ag
# Leave unset to skip Jupiter routability checks (tier scoring still works).

# ── 4.0: Multi-source data ────────────────────────────────────────────────────

# BirdEye API (birdeye.so → free tier → API key required)
# Adds early-breakout signals sorted by 24h volume-change %; leave blank to skip.
BIRDEYE_API_KEY=

# Pump.fun source — uses free DexScreener endpoint, no key needed.
# Surfaces very new pump.fun-originated tokens (typically <2h, sub-$100K liq).
# The risk engine's strict checks apply — most will be filtered out.
PUMPFUN_ENABLED=true

# Cross-source confirmation bonus in opportunity scoring (+8 for 2 sources, +12 for 3)
MULTI_SOURCE_BONUS=true

# Per-source token fetch limit (total candidates = up to 3× this)
MAX_TOKENS_PER_SOURCE=100

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ── Scan ──────────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=30
DEXSCREENER_MAX_TOKENS=100

# ── Anti-scam thresholds ──────────────────────────────────────────────────────
MIN_LIQUIDITY_USD=50000
MIN_VOLUME_24H_USD=25000
MIN_TOKEN_AGE_MINUTES=60
MAX_TOP10_HOLDER_PCT=65

# ── Scoring thresholds ────────────────────────────────────────────────────────
MAX_RISK_SCORE=45
MIN_OPPORTUNITY_SCORE=55
STRONG_BUY_SCORE=75

# ── Alerts ────────────────────────────────────────────────────────────────────
MAX_ALERTS_PER_HOUR=10
ENABLE_TELEGRAM=true
